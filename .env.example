# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_USER=srp_user
DB_PASSWORD=srp_password
DB_NAME=srp_platform
DATABASE_URL=postgresql://srp_user:srp_password@localhost:5432/srp_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=srp_redis_pass
REDIS_URL=redis://:srp_redis_pass@localhost:6379

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_secret
JWT_REFRESH_SECRET=replace_with_64_char_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── n8n Integration ──────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=changeme_n8n
N8N_WEBHOOK_SECRET=replace_with_random_webhook_secret
N8N_BASE_URL=http://localhost:5678

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Set AI_PROVIDER to: openai | openrouter
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...your-openai-key
OPENAI_MODEL=gpt-4o
OPENROUTER_API_KEY=sk-or-...your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# ─── Email (for outreach + notifications) ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp_password
SMTP_FROM=SRP Platform <noreply@example.com>

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001
