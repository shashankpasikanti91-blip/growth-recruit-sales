# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_USER=growth_user
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=growth_platform
DATABASE_URL=postgresql://growth_user:CHANGE_ME_strong_db_password@postgres:5432/growth_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64char_random_secret_abcdef1234567890abcdef1234567890abc
JWT_REFRESH_SECRET=CHANGE_ME_64char_refresh_secret_abcdef1234567890abcdef12345678
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://growth.srpailabs.com

# ─── n8n Integration (uses existing n8n on port 5678) ─────────────────────────
N8N_BASE_URL=http://host.docker.internal:5678
N8N_WEBHOOK_SECRET=CHANGE_ME_n8n_webhook_secret

# ─── AI Provider — OpenRouter gpt-4.1-mini (cheap + fast) ───────────────────
AI_PROVIDER=openrouter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENROUTER_API_KEY=CHANGE_ME_your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_email@gmail.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=SRP AI Labs <noreply@srp-ai-labs.com>

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# ─── S3 / MinIO (Document Storage) ───────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=documents
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
SIGNED_URL_EXPIRY_SECONDS=900
MAX_DOCUMENT_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg,text/plain,text/csv

# ─── Google OAuth (optional — leave empty to disable) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://growth.srpailabs.com/api/v1/auth/google/callback

# ─── External APIs (optional) ────────────────────────────────────────────
APIFY_API_KEY=
GOOGLE_MAPS_API_KEY=
APOLLO_API_KEY=

# ─── Owner Notifications (optional) ──────────────────────────────────────
OWNER_EMAIL=
OWNER_TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_CHAT_ID=

# ─── Frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://growth.srpailabs.com/api
NEXT_PUBLIC_WS_URL=wss://growth.srpailabs.com
# Set to 'true' to show demo login banner on login page
NEXT_PUBLIC_DEMO_MODE=false