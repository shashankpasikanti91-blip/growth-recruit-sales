{
  "id": "04-outreach-sequence",
  "name": "04 - Outreach Sequence Executor",
  "active": true,
  "description": "Handles the actual dispatch of outreach messages generated by the AI. Checks the outreach messages queue, sends via configured channel (Email / LinkedIn), then updates message status back to the backend.",
  "nodes": [
    {
      "id": "n1",
      "name": "Schedule - Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300],
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 30 }] }
      }
    },
    {
      "id": "n2",
      "name": "Fetch Pending Messages",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.BACKEND_URL }}/api/v1/outreach/messages?status=PENDING&limit=10",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer {{ $vars.BACKEND_SERVICE_TOKEN }}" }]
        }
      }
    },
    {
      "id": "n3",
      "name": "Split Into Items",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [680, 300],
      "parameters": { "batchSize": 1 }
    },
    {
      "id": "n4",
      "name": "Route by Channel",
      "type": "n8n-nodes-base.switch",
      "position": [900, 300],
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.channel }}",
        "rules": {
          "rules": [
            { "value2": "EMAIL", "output": 0 },
            { "value2": "LINKEDIN", "output": 1 }
          ]
        }
      }
    },
    {
      "id": "n5",
      "name": "Send Email (SMTP)",
      "type": "n8n-nodes-base.emailSend",
      "position": [1120, 180],
      "parameters": {
        "to": "={{ $json.toEmail }}",
        "subject": "={{ $json.subject }}",
        "text": "={{ $json.body }}"
      }
    },
    {
      "id": "n6",
      "name": "Send LinkedIn (HTTP)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 380],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LINKEDIN_MESSAGING_URL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer {{ $vars.LINKEDIN_TOKEN }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ { recipients: [$json.toLinkedinUrn], body: { text: $json.body } } }}"
      }
    },
    {
      "id": "n7",
      "name": "Mark as SENT",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 300],
      "parameters": {
        "method": "PATCH",
        "url": "={{ $vars.BACKEND_URL }}/api/v1/outreach/messages/{{ $json.id }}/status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "{ \"status\": \"SENT\" }"
      }
    }
  ],
  "connections": {
    "Schedule - Every 30 Minutes": { "main": [[{ "node": "Fetch Pending Messages", "type": "main", "index": 0 }]] },
    "Fetch Pending Messages": { "main": [[{ "node": "Split Into Items", "type": "main", "index": 0 }]] },
    "Split Into Items": { "main": [[{ "node": "Route by Channel", "type": "main", "index": 0 }]] },
    "Route by Channel": {
      "main": [
        [{ "node": "Send Email (SMTP)", "type": "main", "index": 0 }],
        [{ "node": "Send LinkedIn (HTTP)", "type": "main", "index": 0 }]
      ]
    },
    "Send Email (SMTP)": { "main": [[{ "node": "Mark as SENT", "type": "main", "index": 0 }]] },
    "Send LinkedIn (HTTP)": { "main": [[{ "node": "Mark as SENT", "type": "main", "index": 0 }]] }
  },
  "variables": {
    "BACKEND_URL": "http://backend:3001",
    "N8N_WEBHOOK_SECRET": "REPLACE_ME",
    "BACKEND_SERVICE_TOKEN": "REPLACE_ME",
    "LINKEDIN_MESSAGING_URL": "REPLACE_ME",
    "LINKEDIN_TOKEN": "REPLACE_ME"
  }
}
