{
  "id": "02-lead-import",
  "name": "02 - Lead Import (Apollo / Hunter / CSV)",
  "active": true,
  "description": "Pulls leads from Apollo.io search, Hunter.io domain search, or processes an uploaded CSV. Normalises the records and sends them to the backend /webhooks/lead-imported endpoint.",
  "nodes": [
    {
      "id": "n1",
      "name": "Webhook Trigger (CSV Upload)",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 200],
      "parameters": {
        "path": "lead-csv-upload",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "n2",
      "name": "Apollo Search Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 400],
      "parameters": {
        "rule": { "interval": [{ "field": "hours", "hoursInterval": 12 }] }
      }
    },
    {
      "id": "n3",
      "name": "Fetch Apollo Leads",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 400],
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/api/v1/mixed_people/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "X-Api-Key", "value": "={{ $vars.APOLLO_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "{ \"page\": 1, \"per_page\": 25, \"person_seniorities\": [\"manager\", \"director\", \"vp\", \"c_suite\"] }"
      }
    },
    {
      "id": "n4",
      "name": "Merge Sources",
      "type": "n8n-nodes-base.merge",
      "position": [680, 300],
      "parameters": { "mode": "combine", "combineBy": "combineAll" }
    },
    {
      "id": "n5",
      "name": "Normalise Lead",
      "type": "n8n-nodes-base.code",
      "position": [900, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nreturn items.flatMap(item => {\n  const data = item.json.people ?? [item.json];\n  return data.map(p => ({\n    json: {\n      firstName: p.first_name ?? p.firstName ?? '',\n      lastName: p.last_name ?? p.lastName ?? '',\n      email: (p.email_status === 'verified' ? p.email : null) ?? p.email ?? null,\n      phone: p.phone_numbers?.[0]?.sanitized_number ?? null,\n      title: p.title ?? null,\n      linkedinUrl: p.linkedin_url ?? null,\n      company: { name: p.organization?.name ?? p.company ?? null, website: p.organization?.website_url ?? null, industry: p.organization?.industry ?? null, employeeCount: p.organization?.num_employees ?? null },\n      source: 'APOLLO',\n      countryCode: p.country ?? 'MY'\n    }\n  }));\n});"
      }
    },
    {
      "id": "n6",
      "name": "POST to Backend Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.BACKEND_URL }}/api/v1/webhooks/lead-imported",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ $json }}"
      }
    }
  ],
  "connections": {
    "Webhook Trigger (CSV Upload)": { "main": [[{ "node": "Merge Sources", "type": "main", "index": 0 }]] },
    "Apollo Search Trigger": { "main": [[{ "node": "Fetch Apollo Leads", "type": "main", "index": 0 }]] },
    "Fetch Apollo Leads": { "main": [[{ "node": "Merge Sources", "type": "main", "index": 1 }]] },
    "Merge Sources": { "main": [[{ "node": "Normalise Lead", "type": "main", "index": 0 }]] },
    "Normalise Lead": { "main": [[{ "node": "POST to Backend Webhook", "type": "main", "index": 0 }]] }
  },
  "variables": {
    "BACKEND_URL": "http://backend:3001",
    "N8N_WEBHOOK_SECRET": "REPLACE_ME",
    "APOLLO_API_KEY": "REPLACE_ME"
  }
}
